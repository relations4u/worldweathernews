{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"prepare": "pnpm run paraglide:compile && svelte-kit sync || echo ''",
		"check": "pnpm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "pnpm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.3",
		"@tailwindcss/vite": "^4.3.0",
		"@vitest/ui": "^4.1.5",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"lucide-svelte": "^1.0.1",
		"maplibre-gl": "5.24.0",
		"mdsvex": "^0.12.7",
		"postcss": "^8.5.14",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-eslint-parser": "^1.6.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.5"
	}
}
