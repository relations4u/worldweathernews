# pnpm 11+ verifiziert standardmäßig vor jedem Run die Dep-Konsistenz und
# bricht bei ignored builds hart ab. Für unseren Workflow wäre das Noise —
# wir wollen explizit kontrollieren, was gebaut wird (siehe pnpm-workspace.yaml
# allowBuilds:). Pre-flight-Check deshalb aus.
verify-deps-before-run=false
