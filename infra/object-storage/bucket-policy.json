{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicReadMedia",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::media-worldweathernews-prod/site/*",
        "arn:aws:s3:::media-worldweathernews-prod/blog/*",
        "arn:aws:s3:::media-worldweathernews-prod/pages/*",
        "arn:aws:s3:::media-worldweathernews-prod/team/*"
      ]
    }
  ]
}
