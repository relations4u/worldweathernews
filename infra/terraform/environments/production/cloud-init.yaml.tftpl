#cloud-config
users:
  - name: ${deploy_user}
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
%{ for key in authorized_keys ~}
      - ${key}
%{ endfor ~}

package_update: true
package_upgrade: true
packages:
  - python3
  - sudo
  - rsync

runcmd:
  - timedatectl set-timezone Europe/Berlin
