# {{ ansible_managed }}
# Gerendert von der app-Rolle mit konkreten VERSION/IMAGE_NAMESPACE-Werten.
# Caddy läuft NICHT in diesem Stack — siehe infra/caddy/prod/compose.yml.

services:
  postgres:
    image: timescale/timescaledb-ha:pg16
    container_name: wwn-postgres
    restart: unless-stopped
    env_file:
      - {{ app_dir }}/.env.postgres
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - {{ app_dir }}/postgres-init:/docker-entrypoint-initdb.d:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 10
    networks: [wwn-net]

  redis:
    image: redis:7-alpine
    container_name: wwn-redis
    restart: unless-stopped
    command: redis-server --maxmemory 256mb --maxmemory-policy allkeys-lru
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 5
    networks: [wwn-net]

  backend:
    image: ghcr.io/{{ image_namespace }}/wwn-backend:{{ versions.backend }}
    container_name: wwn-backend
    restart: unless-stopped
    env_file:
      - {{ app_dir }}/.env.backend
    ports:
      # 0.0.0.0:8080 → Caddy (via 127.0.0.1) UND Prometheus auf wwn-mon
      # (via 10.100.100.21) erreichen denselben Endpunkt. UFW erlaubt
      # 8080/tcp NUR aus 10.100.100.0/24 (siehe common-Rolle,
      # monitoring_scrape_ports), externe Zugriffe gehen ohnehin über
      # Caddy mit TLS. Caddy reverse_proxy bleibt auf 127.0.0.1:8080.
      - "0.0.0.0:8080:8080"
    depends_on:
      postgres: {condition: service_healthy}
      redis: {condition: service_healthy}
    networks: [wwn-net]

  frontend:
    image: ghcr.io/{{ image_namespace }}/wwn-frontend:{{ versions.frontend }}
    container_name: wwn-frontend
    restart: unless-stopped
    env_file:
      - {{ app_dir }}/.env.frontend
    ports:
      - "127.0.0.1:3000:3000"
    networks: [wwn-net]

  pyworkers:
    image: ghcr.io/{{ image_namespace }}/wwn-pyworkers:{{ versions.pyworkers }}
    container_name: wwn-pyworkers
    restart: unless-stopped
    env_file:
      - {{ app_dir }}/.env.pyworkers
    ports:
      # Prometheus-Scrape von wwn-mon. UFW erlaubt 9100/tcp aus
      # 10.100.100.0/24 (siehe common-Rolle, monitoring_scrape_ports).
      - "0.0.0.0:9100:9100"
    depends_on:
      postgres: {condition: service_healthy}
      redis: {condition: service_healthy}
    networks: [wwn-net]

networks:
  wwn-net:
    name: wwn-net
    driver: bridge

volumes:
  postgres_data:
    name: wwn_postgres_data
