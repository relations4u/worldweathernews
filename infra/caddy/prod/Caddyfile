# Production-Caddyfile für worldweathernews.com.
#
# Caddy läuft mit network_mode: host auf wwn-prod und proxied auf
# 127.0.0.1:{3000,8080} (Frontend / Backend), die der App-Stack unter
# /opt/wwn lokal an Loopback bindet.
{
	email ops@worldweathernews.com
	log {
		output stdout
		format json
	}
}

# 1 Jahr HSTS, KEIN includeSubDomains — manche zukünftige Subdomain (z. B.
# Monitoring) bekommt ggf. lange kein TLS, dann würde sie sonst gesperrt.
(hsts) {
	header Strict-Transport-Security "max-age=31536000"
}

worldweathernews.com {
	import hsts
	reverse_proxy 127.0.0.1:3000
}

www.worldweathernews.com {
	import hsts
	redir https://worldweathernews.com{uri} permanent
}

research.worldweathernews.com {
	import hsts
	reverse_proxy 127.0.0.1:3000
}

api.research.worldweathernews.com {
	import hsts
	encode zstd gzip

	# OPTIONS-Preflights gehen DURCH zum Backend — chi-cors auf Backend-Seite
	# kennt die erlaubten Origins (WWN_HTTP_CORSORIGINS) und antwortet mit den
	# korrekten Access-Control-Allow-* Headern. Caddy hat die Allow-Liste
	# nicht und würde sonst ein 204 ohne CORS-Header zurückgeben → Preflight
	# scheitert, Browser refused die echte Anfrage.
	reverse_proxy 127.0.0.1:8080
}
