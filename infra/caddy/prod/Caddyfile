# Production-Caddyfile für worldweathernews.com — INTERNER HTTP-Router.
#
# Strategie R1 (siehe sysadmin-Repo, ADR-0002): der Internet-Ingress ist jetzt
# `gate` (10.100.100.151). gate terminiert öffentliches TLS + HSTS und reicht alle
# worldweathernews.com-Namen mit erhaltenem Host-Header an diesen Caddy durch.
#
# Dieser Caddy macht daher KEIN ACME mehr (auto_https off) und lauscht nur intern
# auf 10.100.100.70:80 (default_bind). Die App-Routing-Logik bleibt unverändert —
# Caddy läuft weiter mit network_mode: host und erreicht die App auf 127.0.0.1.
#
# HSTS setzt jetzt gate (der TLS-Terminator) — hier nicht mehr nötig.
{
	auto_https off
	default_bind 10.100.100.70
	log {
		output stdout
		format json
	}
}

http://worldweathernews.com {
	reverse_proxy 127.0.0.1:3000
}

http://www.worldweathernews.com {
	redir https://worldweathernews.com{uri} permanent
}

http://research.worldweathernews.com {
	reverse_proxy 127.0.0.1:3000
}

http://api.research.worldweathernews.com {
	encode zstd gzip

	# OPTIONS-Preflights gehen DURCH zum Backend — chi-cors auf Backend-Seite
	# kennt die erlaubten Origins (WWN_HTTP_CORSORIGINS) und antwortet mit den
	# korrekten Access-Control-Allow-* Headern. Caddy hat die Allow-Liste
	# nicht und würde sonst ein 204 ohne CORS-Header zurückgeben → Preflight
	# scheitert, Browser refused die echte Anfrage.
	reverse_proxy 127.0.0.1:8080
}

# Self-hosted GitHub-OAuth-Proxy für Sveltia CMS — ersetzt den vormaligen
# Cloudflare-Worker. Container bindet auf 127.0.0.1:8090 und prüft erlaubte
# Origins selbst (WWN_CMS_AUTH_ALLOWED_DOMAINS in der env-Datei).
http://cms-auth.worldweathernews.com {
	reverse_proxy 127.0.0.1:8090
}

# Media-Bucket-Proxy: Hetzner S3 routet nach Host-Header. Würde der Client-Host
# (media.worldweathernews.com) durchgereicht, antwortet Hetzner 400 BadRequest
# (kein Bucket dieses Namens). Wir rewriten Host auf den virtual-hosted
# Bucket-Endpoint. Schreibzugriffe laufen NICHT über diesen Proxy — Sveltia
# nutzt später pre-signed URLs direkt gegen den Bucket-Endpoint.
http://media.worldweathernews.com {
	encode zstd gzip

	@readonly method GET HEAD
	handle @readonly {
		reverse_proxy https://media-worldweathernews-prod.fsn1.your-objectstorage.com {
			header_up Host media-worldweathernews-prod.fsn1.your-objectstorage.com
		}
	}

	handle {
		header Allow "GET, HEAD"
		respond 405
	}
}
