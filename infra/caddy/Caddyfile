# Caddy-Konfiguration für die lokale Dev-Umgebung.
#
# - auto_https off: keine ACME-Anfragen für *.localhost (würden scheitern).
# - admin off: kein Admin-API-Endpoint (lokal nicht nötig).
# - JSON-Logs auf stdout (kompatibel zu Docker-Log-Drivern).
#
# Wichtig: Alle Site-Adressen mit `http://`-Schema. Ohne Schema und ohne
# expliziten Port würde Caddy mit `auto_https off` auf :443 binden — und
# Port 80 ginge ins Leere.

{
	auto_https off
	admin off
	log {
		output stdout
		format json
	}
}

# Frontend (Vite-Dev-Server, WebSocket für HMR)
http://app.localhost, http://localhost {
	reverse_proxy frontend:5173
}

# Backend-API
http://api.localhost {
	reverse_proxy backend:8080
}

# Mailhog Web-UI (Convenience für lokale Entwicklung)
http://mail.localhost {
	reverse_proxy mailhog:8025
}
