# Lokale Dev-Umgebungsvariablen.
# Kopiere diese Datei nach `.env` (passiert automatisch in `make dev` /
# `make bootstrap`, falls .env fehlt).
#
# .env selbst ist gitignored. Hier NIE Production-Secrets ablegen.

# Compose
COMPOSE_PROJECT_NAME=wwn

# PostgreSQL
POSTGRES_PASSWORD=changeme_in_dev_only

# Backend (kommt in Session 4)
WWN_DATABASE_URL=postgres://wwn:changeme_in_dev_only@postgres:5432/wwn?sslmode=disable
WWN_REDIS_URL=redis://redis:6379/0
WWN_LOG_LEVEL=debug
# JSON ist Default, damit Promtail/Loki strukturierte Felder (level,
# trace_id, request_id) als Labels indexieren kann. Auf 'text' umstellen,
# wenn `docker compose logs` von Hand gelesen wird.
WWN_LOG_FORMAT=json
WWN_ENVIRONMENT=dev
WWN_HTTP_PORT=8080

# Backend Tracing (Session 10) — OTLP gRPC zu Tempo. Endpoint ist host:port
# ohne Schema. Bei Tracing-Enabled aber fehlendem Tempo läuft der Backend
# weiter, OTLP-Exporter retrydet im Hintergrund.
WWN_OBSERVABILITY_TRACING_ENABLED=true
WWN_OBSERVABILITY_TRACING_ENDPOINT=tempo:4317

# Python Workers (kommt in Session 6)
WWN_PY_DATABASE_URL=postgres://wwn:changeme_in_dev_only@postgres:5432/wwn
WWN_PY_REDIS_URL=redis://redis:6379/0
WWN_PY_LOG_LEVEL=debug
WWN_PY_LOG_FORMAT=json

# Pyworkers Tracing (Session 10) — analog zum Backend.
WWN_PY_TRACING_ENABLED=true
WWN_PY_TRACING_ENDPOINT=tempo:4317

# Open-Meteo Worker (Iteration 2.1).
# current: 10-min-Polling (Open-Meteo current-Daten haben 15-min-Granularität,
# ON CONFLICT DO NOTHING auf (location_id, observed_at) dedupliziert).
# hourly: 60-min-Polling für 24-h-Forecast.
WWN_PY_OPEN_METEO_ENABLED=true
WWN_PY_OPEN_METEO_CURRENT_INTERVAL_SECONDS=600
WWN_PY_OPEN_METEO_HOURLY_INTERVAL_SECONDS=3600

# Frontend (kommt in Session 5)
PUBLIC_API_BASE_URL=http://api.localhost
