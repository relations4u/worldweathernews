# Pre-commit-Hooks für worldweathernews.com
#
# Installation: `make bootstrap` ruft `pre-commit install --install-hooks`.
# Manueller Lauf: `pre-commit run --all-files`
#
# Hinweis zu Stage-Filtern:
# - Hooks mit `files:`-Pattern überspringen, wenn keine passenden Files gestaged sind.
# - `pass_filenames: false` bei Tools, die das gesamte Modul scannen (z.B. golangci-lint).

fail_fast: false

repos:
  # ─── Generic ──────────────────────────────────────────────────────────────
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v5.0.0
    hooks:
      - id: check-merge-conflict
      - id: check-added-large-files
        args: ["--maxkb=1024"]
      - id: end-of-file-fixer
      - id: trailing-whitespace
      - id: check-yaml
        # Multi-Document-YAML (z.B. Kubernetes-Manifeste) zulassen.
        args: ["--allow-multiple-documents"]
      - id: check-json
      - id: mixed-line-ending
        args: ["--fix=lf"]

  # ─── Secrets-Scanning ─────────────────────────────────────────────────────
  - repo: https://github.com/gitleaks/gitleaks
    rev: v8.21.2
    hooks:
      - id: gitleaks

  # ─── Go ───────────────────────────────────────────────────────────────────
  # gofmt + goimports kommen aus dem golangci-lint-Hook (run-Linters enthalten
  # `gofmt` und `goimports`). Separate Hooks würden doppelt laufen.
  - repo: local
    hooks:
      - id: golangci-lint
        name: golangci-lint
        entry: bash -c 'cd "$(git rev-parse --show-toplevel)" && command -v golangci-lint >/dev/null && golangci-lint run ./apps/backend/... 2>/dev/null || echo "  (kein Backend-Code, übersprungen)"'
        language: system
        files: ^apps/backend/.*\.go$
        pass_filenames: false

  # ─── Python ───────────────────────────────────────────────────────────────
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.7.4
    hooks:
      - id: ruff
        args: ["--fix"]
      - id: ruff-format

  # ─── YAML ─────────────────────────────────────────────────────────────────
  - repo: https://github.com/adrienverge/yamllint
    rev: v1.35.1
    hooks:
      - id: yamllint
        args: ["-c", ".yamllint"]

  # ─── Dockerfiles ──────────────────────────────────────────────────────────
  - repo: https://github.com/hadolint/hadolint
    rev: v2.13.1-beta
    hooks:
      - id: hadolint-docker
        files: (?i)(^|/)(Dockerfile|.*\.dockerfile)$

  # ─── Frontend (Prettier) ──────────────────────────────────────────────────
  # Läuft auf Frontend-relevante Dateitypen. Plugin-Versionen sind an die
  # Frontend-package.json angelehnt — bei größeren Bumps dort hier mitziehen.
  - repo: https://github.com/pre-commit/mirrors-prettier
    rev: v4.0.0-alpha.8
    hooks:
      - id: prettier
        files: ^apps/frontend/.*\.(svelte|ts|tsx|js|jsx|mjs|cjs|css|html|json|md)$
        additional_dependencies:
          - prettier@3.8.3
          - prettier-plugin-svelte@3.5.1
          - prettier-plugin-tailwindcss@0.8.0
